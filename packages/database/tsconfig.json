{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",

    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",

    "strict": true,
    "esModuleInterop": true,

    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true
  },

  "include": ["src"]
}